---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import DecorativeElements from '@/components/layout/DecorativeElements.astro'
import { projects } from '@/data/projects.ts'
import { themeConfig } from '@/config'
import Ticker from '@/components/layout/Ticker'
import ParallaxHand from '@/components/ui/ParallaxHand'
import { getSortedFilteredPosts } from '@/utils/draft'
import { getExcerpt } from '@/utils/excerpt'
import type { Project } from '@/data/projects'
import { Image, getImage } from 'astro:assets'
import batTopImg from '@/images/BAT_TOP_CROPPED.png'
import batBottomImg from '@/images/BAT_BOTTOM_CROPPED.png'
import starsImg from '@/images/STARS.png'
import globeImg from '@/images/MOVIE_GLOBE.svg'
import claudeDashboardImg from '@/images/claude-dashboard.png'
import tr08Img from '@/images/tr-08.png'
import beatPerMinuteImg from '@/images/beat-per-minute-1-small.png'
import phillipsImg from '@/images/phillips-poc.png'

const posts = await getSortedFilteredPosts()

// Optimize project images
const optimizedProjectImages = {
  claudeDashboard: await getImage({ src: claudeDashboardImg }),
  tr08: await getImage({ src: tr08Img }),
  beatPerMinute: await getImage({ src: beatPerMinuteImg }),
  phillips: await getImage({ src: phillipsImg }),
}
const mostRecentPosts = posts.slice(0, 4)
---

<PortfolioLayout title={themeConfig.site.title} description={themeConfig.site.description}>
  <!-- BAT ZONE 1: covers page-top through bio-top section, clipped at projects border -->
  <!-- Rendered via bg-layer slot so it sits behind PortfolioHeader in the DOM -->
  <Fragment slot="bg-layer">
    <div class="bat-zone-1" aria-hidden="true">
      <Image
        src={batTopImg}
        alt=""
        width="1280"
        height="819"
        class="bat-zone-1-img"
      />
    </div>
  </Fragment>

  <!-- TICKER Component -->
  <div class="pt-4 pb-2.5">
    <Ticker client:load />
  </div>

  <!-- BIO TOP Section (above Projects) -->
  <!-- pt-[174px]: Figma y=514 − (50nav + 239h1 + 0main-pt + 51ticker) = 174px -->
  <div class="relative pl-8 pt-[174px]">
    <div class="bio-top">
      <p>
        An early-stage engineer drawn to <span class="highlight">creative tools</span> and developer experience,
        where my professional background in video and audio production becomes a <span
          class="highlight">technical advantage</span
        >.
      </p>
    </div>

    <div class="bio-stars-divider-top flex justify-center w-full">
      <Image src={starsImg} alt="" width="120" height="20" />
    </div>
  </div>

  <!-- PROJECTS Section -->
  <section class="bordered pl-8 pb-4">
    <h2 class="section-title pt-4">PROJECTS:</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        projects.map((project: Project) => {
          // Map project image to optimized version
          let optimizedImg: any = null
          if (project.image.includes('claude-dashboard')) {
            optimizedImg = optimizedProjectImages.claudeDashboard
          } else if (project.image.includes('tr-08')) {
            optimizedImg = optimizedProjectImages.tr08
          } else if (project.image.includes('beat-per-minute')) {
            optimizedImg = optimizedProjectImages.beatPerMinute
          } else if (project.image.includes('phillips')) {
            optimizedImg = optimizedProjectImages.phillips
          }

          return (
            <div class="project-card">
              {optimizedImg && (
                (() => {
                  const imageSrc = optimizedImg.src;
                  const imageAlt = `${project.title} preview`;
                  const imgElement = <img src={imageSrc} alt={imageAlt} class="project-image" />;

                  // Agent Dashboard links to GitHub, others link to live site
                  const href = project.title === 'Agent Dashboard' ? project.ghLink : project.liveLink;

                  return href ? (
                    <a href={href} target="_blank" rel="noopener noreferrer" class="project-image-link">
                      {imgElement}
                    </a>
                  ) : (
                    imgElement
                  );
                })()
              )}
              <h3 class="project-title">{project.title}</h3>
              <p class="project-description">{project.description}</p>
              <div class="project-footer">
                <div class="project-links">
                  <a
                    href={project.ghLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-link"
                  >
                    GitHub
                  </a>{' '}
                  |{' '}
                  {project.liveLink ? (
                    <a
                      href={project.liveLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-link"
                    >
                      Live
                    </a>
                  ) : (
                    ' '
                  )}
                  {project.blogLink && (
                    <>
                      {' '}
                      |{' '}
                      <a href={project.blogLink} class="project-link">
                        Post
                      </a>
                    </>
                  )}
                </div>
                <p class="project-details">{project.details}</p>
              </div>
            </div>
          )
        })
      }
    </div>
  </section>

  <!-- BIO BOTTOM Section (below Projects) — bat zone 2 wraps this -->
  <!-- Using BAT_BOTTOM_CROPPED.png (1280×543px) from Figma 225:57 -->
  <div class="bat-zone-2-wrapper">
    <div class="bat-zone-2" aria-hidden="true">
      <Image
        src={batBottomImg}
        alt=""
        width="1280"
        height="543"
        class="bat-zone-2-img"
      />
    </div>

    <div class="bat-zone-2-content relative z-10 pl-8">
      <div class="bio-btm">
        <p>
          Bringing 19 years of <span class="highlight">systems thinking and team leadership</span> within
          entertainment for brands like VICE, SPOTIFY, SQUARESPACE & BEYONCÉ to early-stage companies
          building creative tools.
        </p>
      </div>

      <div class="bio-stars-divider flex justify-center w-full">
        <Image src={starsImg} alt="" width="120" height="20" />
      </div>
    </div>
  </div>

  <!-- BLOG Section -->
  <section class="bordered pl-8">
    <h2 class="section-title pt-4">BLOG:</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        mostRecentPosts.map((post) => (
          <div class="blog-card">
            <h3 class="blog-title">
              <a href={`/blog/${post.id}`} class="blog-card-link">
                {post.data.title.length > 18 ? post.data.title.slice(0, 18) + '…' : post.data.title}
              </a>
            </h3>
            <p class="blog-description">{getExcerpt(post.body ?? '')}</p>
            <p class="blog-subheading">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <DecorativeElements />

  <!-- GLOBE Asset -->
  <div class="flex justify-center w-full pt-3" data-globe-container>
    <Image src={globeImg} alt="" width="322" height="164" />
  </div>

  <!-- CONTACT BUTTON -->
  <div class="flex pt-20">
    <a href="mailto:ethana@ethananderson.net" class="btn-touch">
      <span>GET IN TOUCH</span>
    </a>
  </div>

  <!-- SPACING BELOW BUTTON -->
  <div style="padding-top: 120px;"></div>

  <!-- PARALLAX HAND -->
  <ParallaxHand client:load />
</PortfolioLayout>

<style>
  /* portfolio styles:  src/styles/portfolio.css */

  /* Responsive grid adjustments */
  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
