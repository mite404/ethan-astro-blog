---
import '@/styles/global.css'
import BaseLayout from '@/layouts/BaseLayout.astro'
import PortfolioHeader from '@/components/layout/PortfolioHeader.astro'
// import { themeConfig } from '@/config'

const { title, description } = Astro.props
---

<BaseLayout title={title} description={description} type="portfolio">
  <div class="portfolio-layout">
    <!-- bg-layer slot: renders before the header so it sits behind all page content -->
    <slot name="bg-layer" />
    <PortfolioHeader />
    <main class="portfolio-main">
      <slot />
    </main>
  </div>
</BaseLayout>

<style is:global>
  /* Portfolio-specific body styles - dark theme matching Figma design */
  body[data-layout-type='portfolio'] {
    padding: 0;
    max-width: none;
    margin: 0 auto;
    background-color: #1c1c1c !important;
  }

  html:has(body[data-layout-type='portfolio']) {
    background-color: #1c1c1c !important;
  }

  .portfolio-layout {
    /* Fixed-width container - 1280px max, centered */
    max-width: 1280px;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: 1rem;
    margin: 0 auto;
    position: relative; /* Contain absolutely positioned children */
    overflow: hidden; /* Clip overflowing elements like the 1513px hand */
    /*background-color: #282828 !important;*/
  }

  .portfolio-main {
    flex: 1;
    padding-bottom: 0.5rem;
    width: 100%;
  }

  @media (max-width: 1280px) {
    .portfolio-layout {
      max-width: 100%;
      padding: 1rem;
    }
  }
</style>
